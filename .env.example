# App Configuration
PORT=8081
LOG_LEVEL=info

# Recovery Settings
CURSOR_FILE_PATH=./data/cursor.json
CURSOR_REWIND_SECONDS=10

# Go Concurrency Settings
HYDRATION_WORKERS=10
CLASSIFICATION_WORKERS=4

# Ingestion Settings
GRAZE_FEED_URI=at://example.com/app.bsky.feed.generator/news
CONTRAILS_WS_URL=wss://api.graze.social/app/contrail

# Edge Hydration Settings
SLINGSHOT_URL=https://slingshot.microcosm.blue

# LLM Classification Settings
LLM_ENDPOINT=http://localhost:8080/v1/
LLM_MODEL=google/gemma-4-e2b-gguf
LLM_TEMPERATURE=0.0
LLM_API_KEY=

# Ozone & Labeler Settings
OZONE_ENDPOINT=http://localhost:3000
LABELER_DID=did:web:labeler.example.com
OZONE_ADMIN_TOKEN=your-ozone-auth-token
DRY_RUN=false
